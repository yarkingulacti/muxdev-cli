# Copy to .env for local publish/verify and Nexus Docker. Do not commit .env.

# Nexus base URL (scripts use this for upload/verify/manifest base_url).
NEXUS_URL=https://apps.developeryarkin.com
NEXUS_REPO=muxdev-releases
NEXUS_CHANNEL=stable
NEXUS_AUTH=user:password

# Docker Compose (packaging/nexus/docker-compose.yml)
NEXUS_BIND_HOST=127.0.0.1
NEXUS_PORT=8081
# NEXUS_IMAGE_TAG=latest
# NEXUS_JVM_MS=512m
# NEXUS_JVM_MX=2g

# GitHub Actions (Repository → Settings → Secrets):
#   NEXUS_URL=https://apps.developeryarkin.com
#   NEXUS_REPO=muxdev-releases
#   NEXUS_AUTH=<user:password>
# Tag push → Release Please (.github/workflows/release-please.yml):
#   Goreleaser → GitHub Release → Nexus upload → verify latest.json

# Client self-update (default: public GitHub Releases — no env required):
#   muxdev update --check
#
# Optional Nexus manifest instead of GitHub:
# MUXDEV_UPDATE_URL=https://apps.developeryarkin.com/repository/muxdev-releases/stable/latest.json

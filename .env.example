# Copy to .env for local publish/verify. Do not commit .env.
NEXUS_URL=http://5.178.111.150:8081
NEXUS_REPO=muxdev-releases
NEXUS_CHANNEL=stable
NEXUS_AUTH=admin:your-password

# GitHub Actions (Repository → Settings → Secrets):
#   NEXUS_URL, NEXUS_REPO, NEXUS_AUTH
# Tag push (v*) runs .github/workflows/release.yml:
#   Goreleaser → GitHub Release → Nexus upload → verify latest.json

# Client self-update:
# MUXDEV_UPDATE_URL=http://5.178.111.150:8081/repository/muxdev-releases/stable/latest.json
